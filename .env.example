# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_HOST=your-postgres-host
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=your-database-name
POSTGRES_PORT=5432
POSTGRES_SSL=false

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com
CORS_METHODS=GET,POST,PUT,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept
CORS_CREDENTIALS=false

# ============================================================================
# Application Configuration
# ============================================================================
PORT=3000
NODE_ENV=development

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# ============================================================================
# Database Backup Configuration
# ============================================================================
# Enable or disable database backup to S3
BACKUP_DB_TO_S3=false

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_REGION=ap-southeast-1
AWS_COGNITO_USER_POOL_ID=your-user-pool-id
AWS_COGNITO_CLIENT_ID=your-client-id
AWS_COGNITO_CLIENT_SECRET=your-client-secret
AWS_COGNITO_DOMAIN=your-domain.auth.region.amazoncognito.com
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET=your-s3-bucket-name

AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_S3_FOLDER_NAME=your-s3-folder-name
AWS_S3_BASE_PATH=your-s3-base-path
AWS_S3_SUB_FOLDER=your-s3-sub-folder
AWS_S3_PRESIGNED_URL_EXPIRATION=3600

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

DEFAULT_MAX_FILE_SIZE=25